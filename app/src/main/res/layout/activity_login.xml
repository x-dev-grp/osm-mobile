<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/olive_cream"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Logo de la société d'olive -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Logo"
        android:src="@drawable/ic_olive_logo"
        app:tint="@color/olive_green" />

    <!-- Nom de la société -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:letterSpacing="0.1"
        android:text="@string/olive_gold"
        android:textColor="@color/olive_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/extra_virgin_olive_oil"
        android:textColor="@color/olive_gold"
        android:textSize="12sp" />

    <!-- Titre de connexion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/sign_in_to_continue"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- etUsername — referenced in LoginActivity binding -->
    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input_login"
        android:hint="@string/username"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <!-- etPassword — referenced in LoginActivity binding -->
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_input_login"
        android:hint="@string/password"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <!-- tvForgotPassword — referenced in LoginActivity binding -->
    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginBottom="24dp"
        android:padding="4dp"
        android:text="Forgot password?"
        android:textColor="@color/olive_green" />

    <!-- btnLogin — referenced in LoginActivity binding -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/olive_green"
        android:text="Login"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <!-- progressBar — shown during login request -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:indeterminateTint="@color/olive_green"
        android:visibility="gone" />

</LinearLayout>