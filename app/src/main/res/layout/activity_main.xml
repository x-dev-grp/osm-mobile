<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/olive_cream"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/olive_green"
            app:title="OSM Mobile"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvWelcome"
                style="@style/TextAppearance.OSM.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Bonjour, User!" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Orders (OF) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOF"
                    style="@style/Widget.OSM.Card"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/olive_green" />

                        <TextView
                            style="@style/TextAppearance.OSM.CardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Orders (OF)" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mouvement de stock -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStockMovement"
                    style="@style/Widget.OSM.Card"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_stock_movement"
                            app:tint="@color/olive_green" />

                        <TextView
                            style="@style/TextAppearance.OSM.CardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Mouvement de stock" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Historique QC -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQCHistory"
                    style="@style/Widget.OSM.Card"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@color/olive_green" />

                        <TextView
                            style="@style/TextAppearance.OSM.CardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Historique QC" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Nouveau FAB : saisie manuelle (icône de recherche) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabManualEntry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="216dp"
        android:alpha="0.0"
        android:contentDescription="Saisie manuelle"
        android:scaleX="0.0"
        android:scaleY="0.0"
        android:visibility="gone"
        app:backgroundTint="@color/olive_cream"
        app:elevation="6dp"
        app:maxImageSize="24dp"
        app:srcCompat="@android:drawable/ic_menu_search"
        app:tint="@color/olive_green" />

    <!-- FAB pour le scan (caché initialement) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabStartScan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="88dp"
        android:alpha="0.0"
        android:contentDescription="Lancer le scan"
        android:scaleX="0.0"
        android:scaleY="0.0"
        android:visibility="gone"
        app:backgroundTint="@color/olive_green"
        app:elevation="6dp"
        app:maxImageSize="24dp"
        app:srcCompat="@android:drawable/ic_menu_camera"
        app:tint="@android:color/white" />

    <!-- FAB pour l'historique (caché initialement) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabScanHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="152dp"
        android:alpha="0.0"
        android:contentDescription="Historique des scans"
        android:scaleX="0.0"
        android:scaleY="0.0"
        android:visibility="gone"
        app:backgroundTint="@color/olive_cream"
        app:elevation="6dp"
        app:icon="@android:drawable/ic_menu_recent_history"
        app:iconTint="@color/olive_green" />

    <!-- FAB principal pour ouvrir le menu de scan -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnLaunchScan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Actions de scan"
        app:backgroundTint="@color/olive_green"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:maxImageSize="28dp"
        app:rippleColor="#33FFFFFF"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@android:color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>