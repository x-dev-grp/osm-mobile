<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/olive_cream"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Image d'olivier décorative -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Olive branch" />


    <!-- tvWelcome — referenced in MainActivity binding -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"
        android:text="Welcome!"
        android:textColor="@color/olive_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Extra Virgin Olive Oil"
        android:textColor="@color/olive_gold"
        android:textSize="14sp" />

    <!-- Message de bienvenue personnalisé -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quality since 2026"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</LinearLayout>