<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/olive_cream">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/olive_dark"
        app:elevation="6dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/olive_dark"
            app:navigationIconTint="@color/text_white"
            app:titleTextColor="@color/text_white"
            app:subtitleTextColor="@color/olive_light" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════════════
                 CARTE — Informations générales
                 ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/olive_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/olive_light"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="20dp"
                            android:background="@color/olive_green"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            style="@style/DetailSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:layout_marginBottom="0dp"
                            android:text="Informations générales" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="16dp">

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Nom" />
                        <TextView
                            android:id="@+id/tvArticleName"
                            style="@style/DetailValue" />

                        <View style="@style/RowDivider" />

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Catégorie" />
                        <TextView
                            android:id="@+id/tvCategory"
                            style="@style/DetailValue" />

                        <View style="@style/RowDivider" />

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Unité" />
                        <TextView
                            android:id="@+id/tvUnit"
                            style="@style/DetailValue" />

                        <View style="@style/RowDivider" />

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Statut" />
                        <TextView
                            android:id="@+id/tvStatus"
                            style="@style/DetailValue" />

                        <View style="@style/RowDivider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingEnd="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Stock min" />
                                <TextView
                                    android:id="@+id/tvStockMin"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/olive_light" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Stock max" />
                                <TextView
                                    android:id="@+id/tvStockMax"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                        </LinearLayout>

                        <View style="@style/RowDivider" />

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Fournisseur" />
                        <TextView
                            android:id="@+id/tvSupplier"
                            style="@style/DetailValue" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════
                 CARTE — Stock actuel
                 ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/olive_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/olive_light"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="20dp"
                            android:background="@color/olive_gold"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            style="@style/DetailSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:layout_marginBottom="0dp"
                            android:text="Stock actuel" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="16dp">

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Quantité" />

                        <TextView
                            android:id="@+id/tvStockQuantity"
                            style="@style/DetailValue"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/olive_dark" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════
                 CARTE — Emplacement
                 ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/olive_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/olive_light"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="20dp"
                            android:background="@color/olive_brown"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            style="@style/DetailSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:layout_marginBottom="0dp"
                            android:text="Emplacement" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingEnd="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Code" />
                                <TextView
                                    android:id="@+id/tvEmplacementCode"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/olive_light" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Nom" />
                                <TextView
                                    android:id="@+id/tvEmplacementNom"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                        </LinearLayout>

                        <View style="@style/RowDivider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingEnd="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Zone" />
                                <TextView
                                    android:id="@+id/tvEmplacementZone"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/olive_light" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="Type" />
                                <TextView
                                    android:id="@+id/tvEmplacementType"
                                    style="@style/DetailValue" />

                            </LinearLayout>

                        </LinearLayout>

                        <View style="@style/RowDivider" />

                        <TextView
                            style="@style/DetailLabel"
                            android:text="Disponible" />
                        <TextView
                            android:id="@+id/tvEmplacementDisponible"
                            style="@style/DetailValue" />

                        <LinearLayout
                            android:id="@+id/configurationContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>