<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/olive_cream"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Icone olivier -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/reset_password_title"
        android:src="@drawable/ic_olive_tree"
        app:tint="@color/olive_green" />

    <!-- Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/reset_password_title"
        android:textColor="@color/olive_dark"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Instruction -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/reset_password_instruction"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- Champ de saisie -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:boxStrokeColor="@color/olive_green"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="@color/olive_green"
        app:startIconDrawable="@drawable/ic_email"
        app:startIconTint="@color/olive_green">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/identifier_hint"
            android:inputType="textEmailAddress|phone"
            android:maxLines="1"
            android:paddingVertical="12dp"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Bouton Envoyer -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendCode"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/send_code"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="@color/olive_green"
        app:cornerRadius="28dp" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/olive_green"
        android:visibility="gone" />

    <!-- Lien Retour -->
    <TextView
        android:id="@+id/btnBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="?selectableItemBackground"
        android:padding="8dp"
        android:text="@string/back_to_login"
        android:textColor="@color/olive_green"
        android:textSize="14sp" />

</LinearLayout>