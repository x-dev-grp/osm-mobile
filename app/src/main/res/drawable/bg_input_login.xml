<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fond blanc -->
    <solid android:color="@color/text_white" />

    <!-- Coins arrondis -->
    <corners android:radius="12dp" />

    <!-- Bordure vert olive clair -->
