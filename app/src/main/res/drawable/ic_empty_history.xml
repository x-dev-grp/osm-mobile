<?xml version="1.0" encoding="utf-8"?><!--
    selector_chip_filter.xml
    Gère l'apparence des chips de filtre selon leur état
    - Normal (non sélectionné)
    - Sélectionné
    - Pressé (touché)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- État sélectionné -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/material_dynamic_primary60" />
            <padding android:bottom="6dp" android:left="12dp" android:right="12dp" android:top="6dp" />
        </shape>
    </item>

    <!-- État pressé (touché) -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/material_dynamic_primary80" />
            <padding android:bottom="6dp" android:left="12dp" android:right="12dp" android:top="6dp" />
        </shape>
    </item>

    <!-- État normal (non sélectionné) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/material_dynamic_neutral90" />
            <padding android:bottom="6dp" android:left="12dp" android:right="12dp" android:top="6dp" />
        </shape>
    </item>
</selector>