<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.osm_mobile" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/olive_green</item>
        <item name="colorPrimaryVariant">@color/olive_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>

        <item name="colorSecondary">@color/olive_gold</item>
        <item name="colorSecondaryVariant">@color/olive_brown</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <item name="android:colorBackground">@color/olive_cream</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="android:colorPrimaryDark">@color/olive_dark</item>

        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_white</item>

        <item name="android:statusBarColor">@color/olive_dark</item>
        <item name="android:navigationBarColor">@color/olive_cream</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="Theme.osm_mobile.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/olive_green</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.osm_mobile.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/olive_green</item>
        <item name="colorPrimaryDark">@color/olive_dark</item>
        <item name="colorSecondary">@color/olive_gold</item>
    </style>

    <!-- Unified Styles -->
    <style name="Widget.OSM.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">28dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.OSM.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#E3DAC8</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">#FFFDF8</item>
    </style>

    <!-- Elegant Typography -->
    <style name="TextAppearance.OSM.Header" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.OSM.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.OSM.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.OSM.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.OSM.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.OSM.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Ajoutez ceci dans themes.xml à côté de l'autre thème -->
    <style name="Theme.OSMMobile" parent="Theme.osm_mobile">
        <!-- Alias, pas besoin de changer les couleurs -->
    </style>

</resources>